{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "outDir": "./.typecheck",
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "vitest.config.ts",
    "tsdown.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
