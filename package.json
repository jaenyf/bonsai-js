{
  "name": "bonsai-js",
  "version": "0.2.0",
  "description": "A safe, zero-dependency expression language for rules, filters, and templates",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./stdlib": {
      "types": "./dist/stdlib/index.d.mts",
      "import": "./dist/stdlib/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danfry1/bonsai-js.git"
  },
  "homepage": "https://danfry1.github.io/bonsai-js/",
  "bugs": {
    "url": "https://github.com/danfry1/bonsai-js/issues"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "bench:gate": "bun run scripts/perf-gate.ts",
    "check:package": "bun run build && bun run scripts/check-package.ts",
    "lint": "oxlint --deny-warnings src tests scripts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "build:website": "bun website/build.ts",
    "prepare": "test -n \"$CI\" || lefthook install",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test && bun run bench:gate && bun run check:package"
  },
  "keywords": ["expression", "evaluator", "parser", "safe", "sandbox", "template", "pipe", "transform", "formula", "dsl", "ast", "jexl", "compiler"],
  "author": "Daniel Fry",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "jexl": "^2.3.0",
    "lefthook": "^2.1.3",
    "oxlint": "^1.51.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
